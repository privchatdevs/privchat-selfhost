# ── PrivChat self-hosted server ──────────────────────────────────────────────
# EVERYTHING HERE IS OPTIONAL: a bare `npm start` auto-configures the basics on
# first boot - it generates the secrets, detects your VPS public IP for
# PUBLIC_URL, and saves what it generated to <DATA_DIR>/auto-config.json (so
# restarts reuse the same values). Anything you set here always wins.
# Copy this file to .env when you want to customize.

# RECOMMENDED: the full public address of this server. Used for invite links,
# webhook URLs, and your federation identity (user@<this host>). If unset,
# first boot detects the VPS public IP and uses http://<ip>:<port> - which
# works, but is desktop-app-only and unencrypted; set a real HTTPS domain here
# as soon as you have one.
PUBLIC_URL=https://chat.yourdomain.net

# RECOMMENDED: the display name people see when they join. Default "PrivChat Server".
SERVER_NAME=My Server

# Session-cookie signing secret. Auto-generated on first boot if unset. To pin
# your own: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#COOKIE_SECRET=

# AES-256 key for at-rest field encryption. Auto-generated on first boot if
# unset (same one-liner as above). Keep it in backups.
#AES_256_KEY_BASE64=

NODE_ENV=production
PORT=4000

# Where databases, uploads, and the federation signing key live. BACK THIS
# FOLDER UP - it is your server. Defaults to ./data next to the app.
#DATA_DIR=/srv/privchat/data

# Extra browser origins allowed by CORS (comma-separated). Defaults to
# PUBLIC_URL, which is right unless the web app is served from somewhere else.
#APP_ORIGIN=

# ── Federation ───────────────────────────────────────────────────────────────
# on (default): accounts from other PrivChat servers can join yours.
# off: fully private standalone server - no outside identities at all.
FEDERATION=on
# Identity suffix other servers see (user@<name>). Defaults to the PUBLIC_URL
# hostname; only set this if they differ.
#FEDERATION_SERVER_NAME=
# Ed25519 signing key (PKCS8 DER, base64). Leave blank to auto-generate into
# <DATA_DIR>/federation-key.json on first boot. LOSING THE KEY means other
# servers stop trusting yours until they re-learn the new one - keep it (or
# this variable) in your backups.
#FEDERATION_SIGNING_KEY_BASE64=

# ── Media storage (optional) ─────────────────────────────────────────────────
# S3-compatible object storage (Backblaze B2, MinIO, AWS S3, ...) for avatars,
# banners, icons, and attachments. Leave blank to run without media uploads -
# chat still works fine.
S3_KEY_ID=
S3_KEY=
S3_BUCKET=
S3_ENDPOINT=
S3_REGION=us-east-005

# ── Email (optional) ─────────────────────────────────────────────────────────
# SMTP relay for verification codes. Leave SMTP_HOST blank to log codes to the
# server console instead of sending real email (fine for small servers).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
#MAIL_FROM=PrivChat <no-reply@chat.yourdomain.net>

# ── Captcha (optional) ───────────────────────────────────────────────────────
# hCaptcha on login/registration. Leave blank to run without a captcha;
# recommended if you open registration to the public. https://www.hcaptcha.com
HCAPTCHA_SITE_KEY=
HCAPTCHA_SECRET_KEY=

# ── At-rest encryption for server channel messages ───────────────────────────
# ChaCha20-Poly1305 key; when set, channel messages are stored encrypted. On a
# FRESH install this is auto-generated too (encryption on by default); an
# existing plaintext install keeps its posture until you set a key yourself
# (then run scripts/encrypt-server-messages.js once to convert old rows).
# Must decode to exactly 32 bytes: openssl rand -base64 32
# LOSING THIS KEY MAKES ENCRYPTED MESSAGES UNREADABLE - keep it in backups.
#SERVER_MSG_KEY_BASE64=
